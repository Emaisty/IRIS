-- =================================================================================
-- Bundled Update Classes
-- =================================================================================


\class BiBUpd (B : BIMixin) {
  | bi_bupd_bupd : BUpd B
  | bi_bupd_mixin : BiBUpdMixin B bi_bupd_bupd
}

-- \class BiFUpd (B : BIMixin) {
--   | bi_fupd_fupd : FUpd B
--   | bi_fupd_mixin : BiFUpdMixin B bi_fupd_fupd
-- }

-- \class BiBUpdFUpd (B : BIMixin) (Bu : BiBUpd B) (Fu : BiFUpd B) {
--   | bupd_fupd (E : Nat) (P : B.E) :
--     (Bu.bi_bupd_bupd.bupd P) |- (Fu.bi_fupd_fupd.fupd E E P)
-- }


-- =================================================================================
-- Basic Laws for BUpd
-- =================================================================================


\func bupd_intro {B : BIMixin} {Bu : BiBUpd B} (P : B.E) : P |- Bu.bi_bupd_bupd.bupd P
  => Bu.bi_bupd_mixin.bi_bupd_mixin_bupd_intro P

\func bupd_mono {B : BIMixin} {Bu : BiBUpd B} (P Q : B.E) (h : P |- Q)
  : (Bu.bi_bupd_bupd.bupd P) |- (Bu.bi_bupd_bupd.bupd Q)
  => Bu.bi_bupd_mixin.bi_bupd_mixin_bupd_mono P Q h

\func bupd_trans {B : BIMixin} {Bu : BiBUpd B} (P : B.E)
  : (Bu.bi_bupd_bupd.bupd (Bu.bi_bupd_bupd.bupd P)) |- (Bu.bi_bupd_bupd.bupd P)
  => Bu.bi_bupd_mixin.bi_bupd_mixin_bupd_trans P

\func bupd_frame_r {B : BIMixin} {Bu : BiBUpd B} (P R : B.E)
  : ((Bu.bi_bupd_bupd.bupd P) * R) |- (Bu.bi_bupd_bupd.bupd (P * R))
  => Bu.bi_bupd_mixin.bi_bupd_mixin_bupd_frame_r P R


-- =================================================================================
-- Derived Laws for BUpd
-- =================================================================================


\func bupd_frame_l {B : BIMixin} {Bu : BiBUpd B} (R Q : B.E)
  : (R * (Bu.bi_bupd_bupd.bupd Q)) |- (Bu.bi_bupd_bupd.bupd (R * Q))
  => B.<=-transitive
      (sep_comm_lemma R (Bu.bi_bupd_bupd.bupd Q))
      (B.<=-transitive
        (bupd_frame_r Q R)
        (bupd_mono (Q * R) (R * Q) (sep_comm_lemma Q R)))

\func bupd_sep {B : BIMixin} {Bu : BiBUpd B} (P Q : B.E)
  : ((Bu.bi_bupd_bupd.bupd P) * (Bu.bi_bupd_bupd.bupd Q)) |- (Bu.bi_bupd_bupd.bupd (P * Q))
  => B.<=-transitive
      (bupd_frame_r P (Bu.bi_bupd_bupd.bupd Q))
      (B.<=-transitive
        (bupd_mono (P * (Bu.bi_bupd_bupd.bupd Q)) (Bu.bi_bupd_bupd.bupd (P * Q))
          (bupd_frame_l P Q))
        (bupd_trans (P * Q)))


