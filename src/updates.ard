\import Logic
\import Logic.Meta
\import Paths
\import Set
\import Data.Maybe
\import Arith.Nat
\import interface
\import Order.PartialOrder

-- =================================================================================
-- Update Modalities for BI
-- =================================================================================


\class BUpd (B : BIBase)
  | bupd : B.E -> B.E

-- \class FUpd (B : BIBase)
--   | fupd : Nat -> Nat -> B.E -> B.E


-- =================================================================================
-- BUpd Mixin: Axioms for Basic Updates
-- =================================================================================

\class BiBUpdMixin (B : BIMixin) (upd : BUpd B) {
  | bi_bupd_mixin_bupd_intro (P : B.E) : P |- bupd P
  | bi_bupd_mixin_bupd_mono (P Q : B.E) : (P |- Q) -> (bupd P) |- (bupd Q)
  | bi_bupd_mixin_bupd_trans (P : B.E) : (bupd (bupd P)) |- (bupd P)
  | bi_bupd_mixin_bupd_frame_r (P R : B.E) : ((bupd P) * R) |- (bupd (P * R))
}


